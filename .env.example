# ──────────────────────────────────────────────
#  PMDecks — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to source control.
# ──────────────────────────────────────────────

# Firebase project config (safe to expose — protected by Firestore Security Rules)
# Found in Firebase Console → Project Settings → Your Apps → Web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: set to true only when running Firebase emulators locally.
# Leave unset/false to use your real Firebase project during npm run dev.
VITE_USE_FIREBASE_EMULATORS=false

# Firebase project ID shorthand (used by Firebase CLI)
# Same value as VITE_FIREBASE_PROJECT_ID
FIREBASE_PROJECT_ID=
