rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOrgMember(orgId) {
      return orgId != null
        && exists(/databases/$(database)/documents/organizations/$(orgId))
        && request.auth.uid in get(/databases/$(database)/documents/organizations/$(orgId)).data.members;
    }

    function canReadBoardData(boardData) {
      return boardData.userId == request.auth.uid
        || (boardData.visibility == 'org' && isOrgMember(boardData.orgId));
    }

    function canUseOrgFeatures() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.billingPlan in ['mid', 'pro', 'business-small', 'business-growth', 'enterprise']
          || request.auth.token.email in ['bradster8@yahoo.com']
        );
    }

    function orgLimitForPlan(plan) {
      return plan == 'enterprise' ? 999
        : plan == 'business-growth' ? 1
        : plan == 'business-small' ? 1
        : plan == 'pro' ? 2
        : plan == 'mid' ? 1
        : 0;
    }

    function ownedOrgCount() {
      return (
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ownedOrgIds is list)
          ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ownedOrgIds.size()
          : (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.ownedOrgId != null
              ? 1
              : 0
          )
      );
    }

    function canCreateOwnOrganization() {
      return canUseOrgFeatures()
        && ownedOrgCount() < orgLimitForPlan(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.billingPlan);
    }

    function orgSeatLimitForPlan(plan) {
      return plan == 'enterprise' ? 5000
        : plan == 'business-growth' ? 500
        : plan == 'business-small' ? 50
        : plan == 'pro' ? 20
        : plan == 'mid' ? 10
        : 0;
    }

    function orgMemberCountAllowed(ownerId, memberCount) {
      return exists(/databases/$(database)/documents/users/$(ownerId))
        && memberCount <= orgSeatLimitForPlan(get(/databases/$(database)/documents/users/$(ownerId)).data.billingPlan);
    }

    function isGlobalAdmin() {
      return signedIn()
        && (
          request.auth.token.email in ['bradster8@yahoo.com']
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
          )
        );
    }

    function isOrgAdmin(orgId) {
      return orgId != null
        && exists(/databases/$(database)/documents/organizations/$(orgId))
        && request.auth.uid in get(/databases/$(database)/documents/organizations/$(orgId)).data.admins;
    }

    // ── users ──────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if signedIn() && (
        request.auth.uid == uid
        || isGlobalAdmin()
        || (
          // Allow org members to read profiles of other members in the same org
          exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId != null
          && resource.data.organizationId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId
        )
      );
      allow write: if signedIn() && (
        request.auth.uid == uid
        || isGlobalAdmin()
        || (
          request.method == 'update'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['organizationId'])
          && request.resource.data.organizationId != null
          && exists(/databases/$(database)/documents/organizations/$(request.resource.data.organizationId))
          && get(/databases/$(database)/documents/organizations/$(request.resource.data.organizationId)).data.ownerId == request.auth.uid
          && uid in get(/databases/$(database)/documents/organizations/$(request.resource.data.organizationId)).data.members
        )
      );

      // Daily usage counters, e.g. /users/{uid}/usage/ai-2026-04-12
      match /usage/{usageId} {
        allow read, write: if signedIn() && request.auth.uid == uid;
      }
    }

    // ── usernames (username -> uid index) ─────────────────────────────────
    match /usernames/{username} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/usernames/$(username));
      allow update, delete: if false;
    }

    // ── organizations ──────────────────────────────────────────────────────
    match /organizations/{orgId} {
      allow read: if signedIn() && (request.auth.uid in resource.data.members || isGlobalAdmin());
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.members;
      allow update, delete: if signedIn() && canUseOrgFeatures() && (
        resource.data.ownerId == request.auth.uid
        || (
          isOrgAdmin(orgId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'admins', 'memberRoles'])
          && orgMemberCountAllowed(resource.data.ownerId, request.resource.data.members.size())
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.name == resource.data.name
          && request.resource.data.createdAt == resource.data.createdAt
        )
      );
    }

    // ── boards ─────────────────────────────────────────────────────────────
    match /boards/{boardId} {
      allow read: if signedIn() && (canReadBoardData(resource.data) || isGlobalAdmin());
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && (
          request.resource.data.visibility == 'private'
          || (request.resource.data.visibility == 'org' && isOrgMember(request.resource.data.orgId))
        );
      allow update: if signedIn() && (
        resource.data.userId == request.auth.uid
        || (
          resource.data.visibility == 'org'
          && isOrgAdmin(resource.data.orgId)
        )
      );
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // ── cards ──────────────────────────────────────────────────────────────
    match /cards/{cardId} {
      allow read: if signedIn() && (
        isGlobalAdmin()
        ||
        resource.data.userId == request.auth.uid
        || (
          exists(/databases/$(database)/documents/boards/$(resource.data.boardId))
          && canReadBoardData(get(/databases/$(database)/documents/boards/$(resource.data.boardId)).data)
        )
      );

      allow create: if signedIn()
        && exists(/databases/$(database)/documents/boards/$(request.resource.data.boardId))
        && canReadBoardData(get(/databases/$(database)/documents/boards/$(request.resource.data.boardId)).data);

      allow update, delete: if signedIn()
        && exists(/databases/$(database)/documents/boards/$(resource.data.boardId))
        && canReadBoardData(get(/databases/$(database)/documents/boards/$(resource.data.boardId)).data);
    }

    // ── completionLog ────────────────────────────────────────────────────
    match /completionLog/{logId} {
      allow read, write: if signedIn();
    }

    // ── supportTickets ────────────────────────────────────────────────────
    match /supportTickets/{ticketId} {
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow read: if signedIn() && (
        resource.data.uid == request.auth.uid
        || isGlobalAdmin()
      );
      allow update: if signedIn() && isGlobalAdmin();
      allow delete: if false;
    }
  }
}
