rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── users ──────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── boards ─────────────────────────────────────────────────────────────
    // Temporary simplified auth-gated rules while diagnosing permission errors.
    // Re-tighten ownership constraints after connectivity is confirmed.
    match /boards/{boardId} {
      allow read, write: if request.auth != null;
    }

    // ── cards ──────────────────────────────────────────────────────────────
    match /cards/{cardId} {
      allow read, write: if request.auth != null;
    }
  }
}
